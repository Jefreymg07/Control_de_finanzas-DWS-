<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Balance</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f4f8;
            min-height: 100vh;
        }

        /* Navegación consistente */
        nav {
            background: #2c3e50;
            padding: 15px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        nav h1 { color: #fff; font-size: 1.2rem; }

        nav a {
            color: #ecf0f1;
            text-decoration: none;
            margin-left: 20px;
            font-size: 0.9rem;
        }

        nav a:hover { color: #3498db; }

        .container {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .header-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
        }

        .header-row h2 {
            color: #2c3e50;
            font-size: 1.5rem;
            border-left: 4px solid #3498db;
            padding-left: 12px;
        }

        .btn-exportar {
            background: #e67e22;
            color: #fff;
            padding: 10px 20px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: background 0.2s;
        }

        .btn-exportar:hover { background: #d35400; }

        /* Tarjetas de Resumen */
        .resumen-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .card-resumen {
            background: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            text-align: center;
        }

        .card-resumen h4 { color: #7f8c8d; font-size: 0.8rem; text-transform: uppercase; margin-bottom: 10px; }
        .card-resumen p { font-size: 1.5rem; font-weight: 700; }
        
        .txt-ingreso { color: #27ae60; }
        .txt-egreso { color: #e74c3c; }
        .txt-balance { color: #2c3e50; }

        /* Gráfico y Tablas */
        .main-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            padding: 30px;
            margin-bottom: 30px;
        }

        .chart-section {
            max-width: 350px;
            margin: 0 auto 40px;
        }

        .tablas-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        thead { background: #f8f9fa; border-bottom: 2px solid #eee; }
        thead th { padding: 12px; text-align: left; font-size: 0.85rem; color: #7f8c8d; }
        tbody td { padding: 12px; border-bottom: 1px solid #f1f1f1; font-size: 0.9rem; color: #444; }

        @media (max-width: 768px) {
            .resumen-grid, .tablas-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <nav>
        <h1>Control de Finanzas</h1>
        <div>
            <a href="/dashboard">Dashboard</a>
            <a href="/ver-entradas">Entradas</a>
            <a href="/ver-salidas">Salidas</a>
            <a href="/logout">Cerrar Sesión</a>
        </div>
    </nav>

    <div class="container" id="area-reporte">
        <div class="header-row">
            <h2>Balance General</h2>
            <button class="btn-exportar" onclick="generarPDF()">PDF Reporte</button>
        </div>

        <div class="resumen-grid">
            <div class="card-resumen">
                <h4>Total Ingresos</h4>
                <p class="txt-ingreso">$<%= totalEntradas.toFixed(2) %></p>
            </div>
            <div class="card-resumen">
                <h4>Total Egresos</h4>
                <p class="txt-egreso">$<%= totalSalidas.toFixed(2) %></p>
            </div>
            <div class="card-resumen">
                <h4>Balance Neto</h4>
                <p class="txt-balance">$<%= balance.toFixed(2) %></p>
            </div>
        </div>

        <div class="main-card">
            <div class="chart-section">
                <canvas id="balanceChart"></canvas>
            </div>

            <div class="tablas-grid">
                <div>
                    <h4 style="color: #27ae60; border-bottom: 2px solid #27ae60; padding-bottom: 5px;">Detalle Entradas</h4>
                    <table>
                        <thead>
                            <tr><th>Concepto</th><th>Monto</th></tr>
                        </thead>
                        <tbody>
                            <% entradas.forEach(e => { %>
                                <tr>
                                    <td><%= e.detalle %></td>
                                    <td class="txt-ingreso">+$<%= parseFloat(e.monto).toFixed(2) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div>
                    <h4 style="color: #e74c3c; border-bottom: 2px solid #e74c3c; padding-bottom: 5px;">Detalle Salidas</h4>
                    <table>
                        <thead>
                            <tr><th>Concepto</th><th>Monto</th></tr>
                        </thead>
                        <tbody>
                            <% salidas.forEach(s => { %>
                                <tr>
                                    <td><%= s.detalle %></td>
                                    <td class="txt-egreso">-$<%= parseFloat(s.monto).toFixed(2) %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Inicialización de Gráfico
        const tEntradas = Number("<%= totalEntradas %>") || 0;
        const tSalidas = Number("<%= totalSalidas %>") || 0;

        const ctx = document.getElementById('balanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Ingresos', 'Egresos'],
                datasets: [{
                    data: [tEntradas, tSalidas],
                    backgroundColor: ['#27ae60', '#e74c3c'],
                    borderWidth: 0
                }]
            },
            options: {
                plugins: {
                    legend: { position: 'bottom' }
                },
                cutout: '70%'
            }
        });

        // Función para exportar a PDF profesional
        function generarPDF() {
            const element = document.getElementById('area-reporte');
            const opt = {
                margin:       0.5,
                filename:     'Reporte_Balance_Financiero.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
            };

            // Ocultamos el botón de exportar momentáneamente para el PDF
            const btn = document.querySelector('.btn-exportar');
            btn.style.display = 'none';

            html2pdf().set(opt).from(element).save().then(() => {
                btn.style.display = 'block';
            });
        }
    </script>
</body>
</html>